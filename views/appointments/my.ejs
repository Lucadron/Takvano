<div class="text-center mb-4">
  <h2 class="text-info">📅 Randevularım</h2>
</div>

<div class="card card-soft shadow" style="max-width: 900px; margin: auto;">
  <% if (randevularim.length === 0) { %>
    <p class="text-muted text-center">Hiç randevu talebiniz bulunmuyor.</p>
  <% } else { %>
    <table class="table table-bordered text-center align-middle">
      <thead class="table-light">
        <tr>
          <th>Organizatör</th>
          <th>Tarih</th>
          <th>Açıklama</th>
          <th>Durum</th>
        </tr>
      </thead>
      <tbody>
        <% randevularim.forEach(r => { %>
          <tr class="<%= r.durum === 'Kabul Edildi' ? 'table-success' : r.durum === 'Reddedildi' ? 'table-danger' : 'table-warning' %>">
            <td><%= r.organizator.ad %> <%= r.organizator.soyad %></td>
            <td><%= new Date(r.tarih).toLocaleString("tr-TR") %></td>
            <td><%= r.aciklama %></td>
            <td><strong><%= r.durum %></strong></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
