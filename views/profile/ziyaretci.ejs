<div class="text-center mb-4">
  <h2 class="text-primary-blue">👤 Profilim</h2>
  <p class="lead">Bilgilerini güncelle, organizatörler seni daha iyi tanısın.</p>
</div>

<div class="card card-soft shadow" style="max-width: 800px; margin: auto;">
  <% if (mesaj) { %>
    <div class="alert alert-success text-center"><%= mesaj %></div>
  <% } %>

  <form action="/profilim" method="POST" enctype="multipart/form-data">
    <div class="row g-4 align-items-center">
      <div class="col-md-4 text-center">
        <img src="<%= user.profilFoto %>" class="img-thumbnail rounded-profile mb-2" alt="Profil">
        <input type="file" name="profilFoto" id="profilFoto" class="form-control d-none">
        <label for="profilFoto" class="btn btn-outline-primary mt-2">📤 Fotoğraf Yükle</label>
        <div id="dosyaAdi" class="small text-muted mt-1">Seçilen dosya yok</div>
      </div>

      <div class="col-md-8">
        <div class="mb-2"><label>Ad</label><input name="ad" value="<%= user.ad %>" class="form-control" required></div>
        <div class="mb-2"><label>Soyad</label><input name="soyad" value="<%= user.soyad %>" class="form-control" required></div>
        <div class="mb-3"><label>Motto</label><input name="motto" value="<%= user.motto %>" class="form-control" placeholder="Kendini kısaca tanıt"></div>
        <button class="btn btn-takvano w-100">💾 Güncelle</button>
      </div>
    </div>
  </form>
</div>
